# Project-local defaults for run_jupyter_server.sh
#
# This file is sourced by the remote batch script.
# Use the : "${VAR:=value}" pattern so explicit environment variables can override it.

# Use a pre-pulled image, not docker:// at runtime.
: "${JLAB_CONTAINER:=$HOME/containers/framingham-bus.sif}"

# Default to the uv workflow in this project.
: "${JLAB_MODE:=uv}"
: "${JLAB_PYTHON:=3.13}"
: "${JLAB_UV_FROZEN:=1}"

# If this project expects a GPU-backed container session, set this to 1.
: "${JLAB_USE_NV:=0}"
