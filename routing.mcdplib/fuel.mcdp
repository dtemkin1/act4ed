mcdp {
    provides distance [km]

    requires fuel_cost [USD]
    requires emissions [kg]

    constant fuel_cost_per_km = 0.60 USD / km
    constant emissions_per_km = 1.20 kg / km

    required fuel_cost ≥ provided distance * fuel_cost_per_km
    required emissions ≥ provided distance * emissions_per_km
}