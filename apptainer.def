Bootstrap: docker
From: python:3.13-slim

%post
    JULIA_VERSION=1.12.5

    apt-get update
    apt-get install -y --no-install-recommends \
        build-essential \
        git \
        curl \
        ca-certificates \
        gnupg

    mkdir -p /etc/apt/keyrings
    curl -fsSL https://packages.adoptium.net/artifactory/api/gpg/key/public \
        | gpg --dearmor -o /etc/apt/keyrings/adoptium.gpg
    . /etc/os-release
    echo "deb [signed-by=/etc/apt/keyrings/adoptium.gpg arch=$(dpkg --print-architecture)] https://packages.adoptium.net/artifactory/deb ${VERSION_CODENAME} main" \
        > /etc/apt/sources.list.d/adoptium.list

    apt-get update
    apt-get install -y --no-install-recommends temurin-21-jdk

    curl -fsSL "https://julialang-s3.julialang.org/bin/linux/x64/${JULIA_VERSION%.*}/julia-${JULIA_VERSION}-linux-x86_64.tar.gz" \
        | tar -xz -C /opt
    ln -s "/opt/julia-${JULIA_VERSION}" /opt/julia

    mkdir -p /opt/java
    ln -s "$(dirname "$(dirname "$(readlink -f "$(command -v javac)")")")" /opt/java/openjdk

    rm -rf /var/lib/apt/lists/*

    python -m pip install --upgrade pip
    python -m pip install uv jupyterlab ipykernel

%environment
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8
    export JULIA_HOME=/opt/julia
    export JAVA_HOME=/opt/java/openjdk
    export PATH=$JULIA_HOME/bin:$JAVA_HOME/bin:/usr/local/bin:$PATH

%runscript
    exec "$@"
