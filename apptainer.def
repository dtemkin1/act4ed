Bootstrap: docker
From: python:3.11-slim

%post
    apt-get update
    apt-get install -y --no-install-recommends \
        build-essential \
        git \
        curl \
        ca-certificates \
        gnupg

    mkdir -p /etc/apt/keyrings
    curl -fsSL https://packages.adoptium.net/artifactory/api/gpg/key/public \
        | gpg --dearmor -o /etc/apt/keyrings/adoptium.gpg
    . /etc/os-release
    echo "deb [signed-by=/etc/apt/keyrings/adoptium.gpg arch=$(dpkg --print-architecture)] https://packages.adoptium.net/artifactory/deb ${VERSION_CODENAME} main" \
        > /etc/apt/sources.list.d/adoptium.list

    apt-get update
    apt-get install -y --no-install-recommends temurin-21-jdk

    mkdir -p /opt/java
    ln -s "$(dirname "$(dirname "$(readlink -f "$(command -v javac)")")")" /opt/java/openjdk

    rm -rf /var/lib/apt/lists/*

    python -m pip install --upgrade pip
    python -m pip install uv jupyterlab ipykernel

%environment
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8
    export JAVA_HOME=/opt/java/openjdk
    export PATH=$JAVA_HOME/bin:/usr/local/bin:$PATH

%runscript
    exec "$@"
